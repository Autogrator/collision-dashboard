{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/latest", "destination": "/dashboards/latest.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" }
      ]
    }
  ]
}
